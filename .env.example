HERMES_URL=http://127.0.0.1:8642
HERMES_API_KEY=your_api_key_here
A2A_HOST=0.0.0.0
A2A_PORT=9000
A2A_LOG_LEVEL=info
# Public base URL used in file attachment URIs returned to A2A clients.
# Set this when running behind a reverse proxy so file links resolve correctly.
# If unset, defaults to http://<A2A_HOST>:<A2A_PORT>
# A2A_PUBLIC_URL=https://example.com/hermes-a2a
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT=120.0
